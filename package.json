{
    "name": "allowffa-launcher",
    "preductname": "allowffa-launcher",
    "version": "1.0.0",
    "description": "Launcher Mincraft pour le serveur AllowFFA",
    "main": "src/app.js",
    "author": {
        "name": "www.ki-z.fr",
        "email": "kiz@ki-z.fr",
        "url": "https://github.com/KizYTB"
    },
    "url": "http://launcher.allowffa.fr",
    "scripts": {
        "start": "cross-env-shell NODE_ENV=dev electron .",
        "dev": "cross-env-shell DEV_TOOL=open nodemon --exec npm start",
        "build": "node build.js --obf=true --build=platform",
        "icon": "node build.js --icon=https://allowffa.fr/storage/img/logo.png"
    },
    "license": "CCANC",
    "nodemonConfig": {
        "ext": "js,html,css",
        "ignore": "**/test"
    },
    "dependencies": {
        "electron-store": "^8.2.0",
        "electron-updater": "^6.7.3",
        "minecraft-java-core": "^4.2.5",
        "node-fetch": "^2.7.0",
        "xml-js": "^1.6.11"
    },
    "devDependencies": {
        "cross-env": "^10.1.0",
        "electron": "^40.0.0",
        "electron-builder": "^26.0.12",
        "javascript-obfuscator": "^5.1.0",
        "jimp": "^1.6.1",
        "nodemon": "^3.1.11",
        "png2icons": "^2.0.1"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/kizYTB/zekro-rp-Launcher.git"
    }
}
